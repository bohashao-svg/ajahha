{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "RunningHub Duck Decoder",
  "version": "1.1",
  "description": "RunningHub Online Duck Image Decoding Plugin – Boost Work Efficiency Dramatically.",
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
    "downloads",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "*://*.runninghub.ai/*",
    "*://*.runninghub.cn/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.runninghub.cn/*", "*://*.runninghub.ai/*", "*://*.bilibili.com/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["plugin_config.js", "rh_user_helper.js", "content.js", "notification.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject_user_info.js", "injected_verify.js"],
      "matches": ["*://*.runninghub.cn/*", "*://*.runninghub.ai/*", "*://*.bilibili.com/*"]
    }
  ]
}
